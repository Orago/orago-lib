{
	"name": "@orago/lib",
	"version": "0.0.17",
	"description": "Orago's library",
	"scripts": {
		"install": "tsc",
		"build": "npm run build-cjs & npm run build-esm",
		"build-cjs": "npx tsc --module commonjs --moduleResolution node --outDir cjs/",
		"build-esm": "npx tsc --module NodeNext --outDir esm/",
		"test": "echo \"Error: no test specified\" && exit 1"
	},
	"author": "Orago",
	"license": "ISC",
	"exports": {
		"./emitter": {
			"import": "./esm/emitter.js",
			"require": "./cjs/emitter.js"
		},
		"./status": {
			"import": "./esm/status.js",
			"require": "./cjs/status.js"
		},
		"./math": {
			"import": "./esm/math.js",
			"require": "./cjs/math.js"
		},
		"./colors": {
			"import": "./esm/colors.js",
			"require": "./cjs/colors.js"
		},
		"./string": {
			"import": "./esm/string.js",
			"require": "./cjs/string.js"
		},
		"./vector": {
			"import": "./esm/vector.js",
			"require": "./cjs/vector.js"
		}
	},
	"typesVersions": {
		"*": {
			"*": [
				"./src/*"
			]
		}
	},
	"devDependencies": {
		"typescript": "^5.4.5"
	}
}